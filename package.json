{
  "name": "servarr-analytics-mcp",
  "version": "0.1.0",
  "description": "MCP server for Sonarr, Radarr, and Prowlarr analytics, simulation, backup, and bulk operations.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "homepage": "https://github.com/OWNER/servarr-analytics-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OWNER/servarr-analytics-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/OWNER/servarr-analytics-mcp/issues"
  },
  "bin": {
